# ── Application ──────────────────────────────────────────────
APP_NAME=TradeMindAI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trademind.db

# ── NSE / Market Data ──────────────────────────────────────
NSE_BASE_URL=https://www.nseindia.com/api
NSE_HISTORICAL_URL=https://www.nseindia.com/api/historical/cm/equity
NSE_OPTION_CHAIN_URL=https://www.nseindia.com/api/option-chain-indices
NSE_MARKET_STATUS_URL=https://www.nseindia.com/api/marketStatus
NSE_COOKIES_PATH=./data/nse_cookies.json
DATA_FETCH_TIMEOUT=30
DATA_RETRY_ATTEMPTS=3
DATA_RETRY_DELAY=5

# ── API Keys (optional third-party data) ───────────────────
NSEAPI_KEY=
ALPHA_VANTAGE_KEY=
TWELVE_DATA_KEY=
NEWS_API_KEY=

# ── Scheduler ──────────────────────────────────────────────
SCHEDULER_MARKET_DATA_INTERVAL_MINUTES=5
SCHEDULER_OPTION_CHAIN_INTERVAL_MINUTES=15
SCHEDULER_ML_RETRAIN_INTERVAL_HOURS=24
SCHEDULER_PATTERN_DISCOVERY_INTERVAL_HOURS=6
SCHEDULER_REPORT_GENERATION_HOUR=16

# ── ML Model Paths ─────────────────────────────────────────
ML_MODEL_DIR=./models
ML_SCORING_MODEL=scoring_model_v1.pkl
ML_PATTERN_MODEL=pattern_model_v1.pkl
ML_ENSEMBLE_MODEL=ensemble_model_v1.pkl

# ── Scoring Weights ────────────────────────────────────────
WEIGHT_MOMENTUM=0.20
WEIGHT_VOLUME=0.15
WEIGHT_OPTION_CHAIN=0.20
WEIGHT_TECHNICAL=0.15
WEIGHT_FUNDAMENTAL=0.10
WEIGHT_VOLATILITY=0.10
WEIGHT_SENTIMENT=0.10

# ── Trading Parameters ─────────────────────────────────────
DEFAULT_POSITION_SIZE_PERCENT=2.0
MAX_POSITION_SIZE_PERCENT=5.0
MAX_DRAWDOWN_PERCENT=10.0
STOP_LOSS_ATR_MULTIPLIER=2.0
TARGET_RISK_REWARD_RATIO=2.5
MAX_CONCURRENT_TRADES=10
PAPER_TRADE_INITIAL_CAPITAL=1000000

# ── Risk Management ────────────────────────────────────────
MAX_PORTFOLIO_RISK_PERCENT=15.0
MAX_SINGLE_TRADE_RISK_PERCENT=2.0
MIN_SCORE_THRESHOLD=65.0
HIGH_CONFIDENCE_THRESHOLD=80.0

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
CORS_ORIGINS=["http://localhost:3000"]
